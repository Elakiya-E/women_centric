datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Service {
  id            String    @id @default(uuid())
  title         String
  description   String
  startingPrice String
  rating        Float
  badge         String
  iconName      String    // e.g. "Plane", "Train", "HeartPulse"
  gradient      String    // e.g. "from-[#FF9E7D] to-[#E07A5F]"
  slug          String?   @unique
  categorySlug  String?   // "home-care", "repair", "security", "travel", "lifestyle"
  isPremium     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt
  bookings      Booking[]
  subServices   SubService[]
  caseStudies   CaseStudy[]
  availability  ServiceAvailability?
}

model SubService {
  id          String   @id @default(uuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  title       String
  description String?
  price       String?
  createdAt   DateTime @default(now())
}

model ServiceAvailability {
  id        String   @id @default(uuid())
  serviceId String   @unique
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  cities    String[]
  createdAt DateTime @default(now())
}

model CaseStudy {
  id        String   @id @default(uuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  title     String
  challenge String
  solution  String
  outcome   String
  createdAt DateTime @default(now())
}

model Booking {
  id          String   @id @default(uuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  name        String
  phone       String
  city        String
  date        String
  time        String
  requirement String
  status      String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, etc.
  attendantId String?
  attendant   Attendant? @relation(fields: [attendantId], references: [id])
  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  latitude    Float?
  longitude   Float?

  // Phase 2: Enhanced Booking Fields
  receiverName       String?
  receiverRelation   String?
  receiverGender     String?
  receiverAge        Int?
  specialMedicalReqs String?
  providerPreference String?   @default("Only Women")
  acknowledgement    Boolean   @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendant {
  id                     String   @id @default(uuid())
  name                   String
  role                   String
  experience             String
  languages              String[]
  rating                 Float
  certifications         String[]
  bgGradient             String
  bookings               Booking[]
  account                AttendantAccount?
  location               AttendantLocation?
  notifications          Notification[]
  sessions               SessionLog[]

  // New Profile Fields
  email                  String?
  address                String?
  state                  String?  @default("Tamil Nadu")
  pinCode                String?
  emergencyContact       String?
  profilePhotoBase64     String?

  // Service Specializations
  selectedServices       String[]
  selectedSubServices    Json?
  subServiceExperience   Json?

  // Availability & Working Preferences
  workingDays            String[]
  availableFrom          String?
  availableTo            String?
  preferredWorkingShift  String?
  preferredCities        String[]

  // Uploaded Documents (base64)
  aadhaarBase64          String?
  aadhaarStatus          String   @default("Pending")
  panCardBase64          String?
  panStatus              String   @default("Pending")
  drivingLicenseBase64   String?
  dlStatus               String   @default("Pending")
  professionalCertBase64 String?
  certificatesStatus     String   @default("Pending")
  policeVerifBase64      String?
  policeVerifStatus      String   @default("Pending")
  nursingDegreeBase64    String?
  nursingRegCertBase64   String?
  physioDegreBase64      String?
  physioRegCertBase64    String?
  experienceProofBase64  String?
  criminalBgCheckBase64  String?

  status                 AttendantStatus @default(AVAILABLE)
  availabilityPercentage Float @default(0)

  // Verification
  verificationStatus     String   @default("Registration Submitted")

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Offer {
  id          String   @id @default(uuid())
  title       String
  desc        String
  discount    String   // e.g. "15% OFF"
  code        String   @unique
  bgGradient  String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id        String   @id @default(uuid())
  title     String
  category  String   // e.g. "Women Safety", "Senior Citizen Care"
  desc      String
  readTime  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  location  String
  rating    Int
  review    String
  initials  String
  bgClass   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// New enums for operational status
enum AttendantStatus {
  AVAILABLE
  BUSY
  OFFLINE
  ON_DUTY
}

enum CustomerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Customer {
  id                 String   @id @default(uuid())
  name               String
  phone              String   @unique
  email              String?
  verificationStatus CustomerVerificationStatus @default(PENDING)
  idDocumentType     String?
  idDocumentBase64   String?
  verificationDate   DateTime?
  totalBookings      Int      @default(0)
  bookings           Booking[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// New models for authentication, location, notifications, and sessions
model AttendantAccount {
  id           String   @id @default(uuid())
  attendant    Attendant @relation(fields: [attendantId], references: [id])
  attendantId  String   @unique
  mobileNumber String   @unique
  email        String   @unique @default("test@example.com")
  passwordHash String
  status       AttendantStatus @default(AVAILABLE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AttendantLocation {
  id           String   @id @default(uuid())
  attendant    Attendant @relation(fields: [attendantId], references: [id])
  attendantId  String   @unique
  city         String
  latitude     Float
  longitude    Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id           String   @id @default(uuid())
  type         String   // e.g., NEW_BOOKING, ASSIGNMENT, COMPLETED, EMERGENCY, FEEDBACK
  message      String
  attendant    Attendant? @relation(fields: [attendantId], references: [id])
  attendantId  String?
  read         Boolean @default(false)
  createdAt    DateTime @default(now())
}

model SessionLog {
  id           String   @id @default(uuid())
  token        String   @unique
  expiresAt    DateTime
  attendant    Attendant? @relation(fields: [attendantId], references: [id])
  attendantId  String?
  createdAt    DateTime @default(now())
}

model AttendantRegistration {
  id                     String   @id @default(uuid())

  // Section 1 — Personal Info
  fullName               String
  profilePhotoBase64     String?
  dateOfBirth            String
  age                    Int
  mobileNumber           String   @unique
  email                  String
  password               String   @default("password123")
  address                String
  city                   String
  state                  String
  pinCode                String
  emergencyContact       String

  // Section 2 — Service Profile
  selectedServices       String[]
  selectedSubServices    Json? // Store { serviceName: [subService1, subService2] }
  subServiceExperience   Json? // Store { subServiceName: years }

  // Section 2 — Professional Availability & Working Preferences
  workingDays            String[]
  availableFrom          String? // "08:00 AM" format
  availableTo            String? // "07:00 PM" format
  preferredWorkingShift  String? // "Morning Shift", "Afternoon Shift", "Evening Shift", "Night Shift", "Flexible"
  preferredCities        String[]

  // Section 3 — Skills & Experience
  yearsOfExperience      Int
  languagesKnown         String[]
  certifications         String?
  specialSkills          String?
  previousExperience     String?

  // Section 4 — Documents (base64)
  aadhaarBase64          String?
  drivingLicenseBase64   String?
  panCardBase64          String?
  professionalCertBase64 String?
  policeVerifBase64      String?
  nursingDegreeBase64    String?
  nursingRegCertBase64   String?
  physioDegreBase64      String?
  physioRegCertBase64    String?
  experienceProofBase64  String?
  criminalBgCheckBase64  String?

  // Section 6 — Background Verification Checklist (Admin-controlled)
  bgvAadhaarVerified            Boolean @default(false)
  bgvPanVerified                Boolean @default(false)
  bgvPoliceVerified             Boolean @default(false)
  bgvCriminalBgCheck            Boolean @default(false)
  bgvNeighbourhoodEnquiry       Boolean @default(false)
  bgvAddressVerified            Boolean @default(false)
  bgvEmploymentHistoryChecked   Boolean @default(false)
  bgvReferencesVerified         Boolean @default(false)
  bgvExperienceVerified         Boolean @default(false)
  verificationProgress          String  @default("SUBMITTED") // SUBMITTED, IN_PROGRESS, VERIFIED, APPROVED

  // Section 7/8 — Registration Status & Admin Review
  status                 String   @default("Pending Approval")
  rejectionReason        String?
  adminNotes             String?
  approvalStatus         String   @default("Pending Approval")
  approvedAt             DateTime?
  accountStatus          String   @default("Inactive")

  // Registration Step Tracking (8-step flow)
  registrationStep       Int      @default(1) // 1-8

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Phase 2: Ecosystem Partners
model PartnerEnquiry {
  id             String   @id @default(uuid())
  orgName        String
  contactPerson  String
  email          String
  phone          String
  orgType        String   // "Women NGO", "Nursing College", etc.
  message        String?
  status         String   @default("Pending") // Pending, Reviewed, Approved, Rejected
  adminNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
